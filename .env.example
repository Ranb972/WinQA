# Clerk Authentication
# Get your keys from: https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxx
CLERK_SECRET_KEY=sk_live_xxxxx

# MongoDB
# Get your connection string from: https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/winqa

# App URL (your production domain)
NEXT_PUBLIC_APP_URL=https://your-domain.vercel.app

# LLM API Keys (optional - users can provide their own in Settings)
# Cohere: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_key

# Google Gemini: https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=your_google_key

# Groq: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key

# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key

# Code Execution (optional)
# Judge0: https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_KEY=your_judge0_key
